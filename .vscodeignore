# Sources & build intermediates (only dist/ ships)
src/**
out/**
**/*.ts
**/*.map
tsconfig.json
esbuild.js

# esbuild bundles production deps into dist/extension.js,
# so node_modules is dev-only weight
node_modules/**
package-lock.json

# Tests
.vscode-test/**
.vscode-test.mjs
**/*.test.js

# Local log samples / scratch data (this extension parses .jsonl logs —
# real session samples must never ship)
**/*.jsonl
samples/**
fixtures/**
*.log
*.vsix

# Dev configs & tooling
.vscode/**
.github/**
.gitignore
.gitattributes
.editorconfig
eslint.config.mjs

# AI-assistant state
CLAUDE.md
.claude/**

# Stray root assets (media/** is re-included — runtime assets live there)
Claude .png
*.png
!media/**
